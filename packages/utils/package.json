{
  "name": "@caratflow/utils",
  "version": "0.1.0",
  "private": true,
  "description": "CaratFlow utility functions - money, weight, purity, tax, validation",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
    "./money": { "types": "./dist/money.d.ts", "default": "./dist/money.js" },
    "./weight": { "types": "./dist/weight.d.ts", "default": "./dist/weight.js" },
    "./purity": { "types": "./dist/purity.d.ts", "default": "./dist/purity.js" },
    "./tax": { "types": "./dist/tax.d.ts", "default": "./dist/tax.js" },
    "./validators": { "types": "./dist/validators.d.ts", "default": "./dist/validators.js" },
    "./rates": { "types": "./dist/rates.d.ts", "default": "./dist/rates.js" },
    "./date": { "types": "./dist/date.d.ts", "default": "./dist/date.js" }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@caratflow/shared-types": "workspace:*"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "typescript": "^5.7.0",
    "@vitest/coverage-v8": "^2.1.0",
    "vitest": "^2.1.0"
  }
}
