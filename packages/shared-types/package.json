{
  "name": "@caratflow/shared-types",
  "version": "0.1.0",
  "private": true,
  "description": "Shared types, Zod schemas, and enums for CaratFlow",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
    "./enums": { "types": "./dist/enums.d.ts", "default": "./dist/enums.js" },
    "./events": { "types": "./dist/events.d.ts", "default": "./dist/events.js" },
    "./common": { "types": "./dist/common.d.ts", "default": "./dist/common.js" }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist",
    "lint": "eslint src/"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "typescript": "^5.7.0",
    "vitest": "^2.1.9"
  }
}
