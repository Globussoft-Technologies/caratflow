{
  "name": "caratflow",
  "version": "0.1.0",
  "private": true,
  "description": "CaratFlow - Jewelry ERP System",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:coverage:utils": "pnpm --filter @caratflow/utils exec vitest run --coverage",
    "test:coverage:api": "pnpm --filter @caratflow/api exec vitest run --coverage",
    "test:coverage:all": "pnpm test:coverage:utils && pnpm test:coverage:api",
    "test:utils": "pnpm --filter @caratflow/utils test",
    "test:api": "pnpm --filter @caratflow/api test",
    "test:e2e": "pnpm --filter @caratflow/api exec vitest run --config vitest.e2e.config.ts",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "db:generate": "pnpm --filter @caratflow/db generate",
    "db:push": "pnpm --filter @caratflow/db db:push",
    "db:seed": "pnpm --filter @caratflow/db seed",
    "db:demo-seed": "pnpm --filter @caratflow/db demo-seed",
    "db:realistic-seed": "pnpm --filter @caratflow/db realistic-seed",
    "db:studio": "pnpm --filter @caratflow/db studio",
    "clean": "turbo run clean && rimraf node_modules"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "prettier": "^3.4.0",
    "rimraf": "^6.0.1",
    "turbo": "^2.3.0",
    "@vitest/coverage-v8": "^2.1.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
