# ─── Database (MySQL) ───────────────────────────────────────────
DATABASE_URL="mysql://caratflow:caratflow_pass@localhost:3306/caratflow"
MYSQL_ROOT_PASSWORD=caratflow_root
MYSQL_DATABASE=caratflow
MYSQL_USER=caratflow
MYSQL_PASSWORD=caratflow_pass

# ─── Redis ──────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Auth / JWT ─────────────────────────────────────────────────
JWT_SECRET="change-me-in-production-min-32-chars-long"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# ─── Meilisearch ────────────────────────────────────────────────
MEILI_URL="http://localhost:7700"
MEILI_MASTER_KEY="caratflow_meili_key"

# ─── MinIO / S3 ─────────────────────────────────────────────────
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="caratflow"
S3_SECRET_KEY="caratflow_minio"
S3_BUCKET="caratflow"
S3_REGION="us-east-1"
MINIO_ROOT_USER=caratflow
MINIO_ROOT_PASSWORD=caratflow_minio

# ─── App ────────────────────────────────────────────────────────
NODE_ENV="development"
API_PORT=4000
API_URL="http://localhost:4000"
WEB_URL="http://localhost:3000"

# ─── CORS ───────────────────────────────────────────────────────
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"

# ─── Rate API (Gold/Silver prices) ─────────────────────────────
RATE_API_URL=""
RATE_API_KEY=""
